# HuggingFace token (required for gated models)
HF_TOKEN=your_token_here

# --- RunPod Serverless Load Balancer ---
# PUBLIC_PORT is where caddy listens; RunPod LB attaches to this port.
# PORT is vLLM's internal port (caddy proxies /ping and /v1/* to it).
# PUBLIC_PORT=8000
# PORT=1234

# Set MODEL_DOWNLOAD=1 to auto-fetch weights on cold start when /data/models
# is empty (e.g. first boot on a fresh Network Volume). Default 0 assumes
# the volume is pre-populated.
# MODEL_DOWNLOAD=0

# CHAT_TEMPLATE_KWARGS is a JSON dict passed to vLLM via
# --default-chat-template-kwargs. Defaults to keeping prior <think>
# blocks in the prompt across multi-turn chats. Set to an empty string
# to disable. Per-request chat_template_kwargs always override.
# CHAT_TEMPLATE_KWARGS={"preserve_thinking":true}

# CHAT_TEMPLATE_PATH points at a Jinja template that overrides the one
# bundled with the model. The image bakes the vendored froggeric v9
# template at /etc/vllm/chat_template.jinja, which fixes the
# "System message must be at the beginning" assertion plus several other
# bugs in the stock Qwen3.6 template. Set to an empty string to fall
# back to the model's bundled template. See chat-templates/README.md.
# CHAT_TEMPLATE_PATH=/etc/vllm/chat_template.jinja

# KV_CACHE_DTYPE picks the KV cache quantization. Default is fp8 (~2x KV
# vs FP16, lossless for practical purposes). vllm 0.20.1 (current pin)
# raises NotImplementedError if you set turboquant_* on Qwen3.6 because
# Qwen3.6 is a hybrid attention+Mamba/GDN model and TurboQuant on hybrid
# only landed in PR #39931 (post-v0.20.1). The merge-commit wheel was
# tried and OOMs at cold start on 1x4090 24 GB, so the image is back on
# stable vllm + fp8. Re-evaluate once a tagged release ships #39931.
# KV_CACHE_DTYPE=fp8

# MAX_NUM_BATCHED_TOKENS caps tokens per forward pass (= prefill chunk size
# when --enable-chunked-prefill is on). Larger = fewer chunks per long prompt
# = lower TTFT, at the cost of activation memory (vLLM reserves buffers sized
# to this value during the profile_run cold-start step).
# Image bakes 4128 (= 4096 + 32, matches vLLM's CUDA-graph capture endpoint;
# safe on 1x4090 24 GB + fp8 KV + MML 32768).
# docker-entrypoint.sh auto-scales by detected GPU count when this var still
# matches the baked sentinel "4128":
#   TP=1  -> 4128   (kept; safe on 24 GB single GPU)
#   TP=2  -> 8192   (sharded weights free per-GPU memory)
#   TP>=4 -> 16384  (best for long-prompt agents)
# Set explicitly to override the auto-scale (e.g. 8192 on 1xA6000 48 GB for
# ~halved TTFT on long prompts at ~600 MB extra activation cost). Raising
# past 4128 on a single 24 GB card risks cold-start OOM.
# MAX_NUM_BATCHED_TOKENS=4128
